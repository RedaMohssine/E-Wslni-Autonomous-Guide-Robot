# ============================================================
#  E-Wslni — UI + Chatbot  |  Environment variables template
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ============================================================


# ------------------------------------------------------------------
# REQUIRED — API keys (the app will not start without these)
# ------------------------------------------------------------------

# OpenAI API key — used for the LLM (GPT-4o-mini) and embeddings
OPENAI_API_KEY=sk-...

# Cartesia API key — used for text-to-speech (robot speaker)
CARTESIA_API_KEY=...


# ------------------------------------------------------------------
# OPTIONAL — LangSmith tracing (comment out to disable)
# ------------------------------------------------------------------

LANGSMITH_API_KEY=...
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=e-wslni


# ------------------------------------------------------------------
# OPTIONAL — Robot connection
#
# Two dispatch backends are supported (pick one):
#
#   1. Hub (recommended for Railway deployment)
#      Set HUB_URL and HUB_TOKEN.
#      The hub forwards navigation commands to the robot over a
#      persistent WebSocket — no inbound port needed on the robot.
#
#   2. Rosbridge (local dev / direct connection)
#      Set ROSBRIDGE_URL (and optionally ROS_NAVIGATION_TOPIC).
#
# If neither is set, navigation commands are logged but not sent.
# ------------------------------------------------------------------

# Option 1 — Hub
HUB_URL=https://your-hub.railway.app
HUB_TOKEN=...

# Option 2 — Rosbridge (direct)
# ROSBRIDGE_URL=ws://robot-ip:9090
# ROS_NAVIGATION_TOPIC=/navigation_goal


# ------------------------------------------------------------------
# OPTIONAL — App settings
# ------------------------------------------------------------------

# Directory where conversation memories are stored (default: ./memories)
# APP_MEMORY_BASE=./memories
