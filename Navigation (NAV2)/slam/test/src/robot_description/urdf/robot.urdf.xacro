<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mobile_robot">

  <!-- Include Gazebo properties -->
  <xacro:include filename="$(find robot_description)/urdf/robot.gazebo.xacro" />

  <!-- Define constants -->
  <!-- Octagon: 255mm per side, circumradius = 0.255 / (2*sin(pi/8)) = 0.3332m -->
  <!-- Width across flats = 0.255 * (1 + sqrt(2)) = 0.6156m -->
  <xacro:property name="octagon_side" value="0.255"/>
  <xacro:property name="octagon_circumradius" value="0.3332"/>
  <xacro:property name="base_width" value="0.6156"/>
  <xacro:property name="base_length" value="0.6156"/>
  <xacro:property name="base_height" value="0.40"/>
  <xacro:property name="base_mass" value="10.0"/>
  
  <xacro:property name="wheel_radius" value="0.10"/>
  <xacro:property name="wheel_width" value="0.05"/>
  <xacro:property name="wheel_mass" value="2.0"/>
  <xacro:property name="wheel_separation" value="0.488"/>
  
  <xacro:property name="caster_radius" value="0.10"/>
  <xacro:property name="caster_mass" value="0.5"/>
  <xacro:property name="caster_x_offset" value="0.20"/>
  
  <!-- Center of mass offset: d/3 from wheels axis toward caster -->
  <!-- This is the optimal position for differential drive robots -->
  <xacro:property name="com_x_offset" value="${caster_x_offset / 3.0}"/>
  
  <!-- Define inertial macro for box -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <origin xyz="${com_x_offset} 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0"
               iyy="${(m/12) * (w*w + d*d)}" iyz="0.0"
               izz="${(m/12) * (w*w + h*h)}"/>
    </inertial>
  </xacro:macro>
  
  <!-- Define inertial macro for cylinder -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy="0.0" ixz="0.0"
               iyy="${(m/12) * (3*r*r + h*h)}" iyz="0.0"
               izz="${(m/2) * r*r}"/>
    </inertial>
  </xacro:macro>
  
  <!-- Define inertial macro for sphere -->
  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia ixx="${(2/5) * m * r * r}" ixy="0.0" ixz="0.0"
               iyy="${(2/5) * m * r * r}" iyz="0.0"
               izz="${(2/5) * m * r * r}"/>
    </inertial>
  </xacro:macro>

  <!-- Base footprint (virtual link on the ground) -->
  <link name="base_footprint"/>

  <!-- Base link (main chassis - octagon with 255mm sides) -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/octagon_base.stl"/>
      </geometry>
      <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- Use cylinder for collision to avoid Gazebo mesh physics instabilities -->
        <cylinder radius="${octagon_circumradius}" length="${base_height}"/>
      </geometry>
    </collision>
    <!-- Approximate inertia using bounding box -->
    <xacro:box_inertia m="${base_mass}" w="${base_width}" h="${base_height}" d="${base_length}"/>
  </link>

  <!-- Joint connecting base_footprint to base_link -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- Wheel macro -->
  <xacro:macro name="wheel" params="prefix reflect">
    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="0 ${reflect * wheel_separation/2} ${-base_height/2}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>
  </xacro:macro>

  <!-- Left and right wheels -->
  <xacro:wheel prefix="left" reflect="1"/>
  <xacro:wheel prefix="right" reflect="-1"/>

  <!-- Caster wheel (passive sphere) -->
  <link name="caster_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}"/>
  </link>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="${caster_x_offset} 0 ${-base_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- LiDAR Sensor -->
  <xacro:property name="lidar_radius" value="0.05"/>
  <xacro:property name="lidar_height" value="0.07"/>
  <xacro:property name="lidar_mass" value="0.2"/>

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.1 0.1 1.0"/>
      </material>
    </visual>
    <!-- Collision disabled to prevent LiDAR from detecting itself -->
    <!--
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>
    -->
    <xacro:cylinder_inertia m="${lidar_mass}" r="${lidar_radius}" h="${lidar_height}"/>
  </link>

    <!-- LiDAR at 582mm from ground. base_link origin at wheel_radius (100mm) from ground.
      So lidar_link z = 0.582 - wheel_radius = 0.482m above base_link origin.
      x = -0.00862m: LiDAR is 8.62mm behind robot centre (confirmed from working mapping project). -->
    <xacro:property name="lidar_z_from_base" value="${0.582 - wheel_radius}"/>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="-0.00862 0 ${lidar_z_from_base}" rpy="0 0 0"/>
  </joint>

</robot>
